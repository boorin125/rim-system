# ════════════════════════════════════════
#  RIM System — Environment Configuration
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่า
#  (install.sh จะสร้างไฟล์นี้ให้อัตโนมัติ)
# ════════════════════════════════════════

# URL ของระบบ (ใส่ domain หรือ IP ของ server)
# ตัวอย่าง: https://rim.yourcompany.com หรือ http://192.168.1.100
APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# Database
DB_NAME=rimdb
DB_USER=rimuser
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT Secret (สุ่มตัวเลข-ตัวอักษร อย่างน้อย 32 ตัว)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY_MIN_32_CHARS

# Machine ID (ใช้ระบุ server สำหรับ License — ดึงจาก /etc/machine-id)
MACHINE_ID=CHANGE_THIS_TO_MACHINE_ID

# License Key (รับจาก Rubjobb Development Team)
LICENSE_KEY=XXXX-XXXX-XXXX-XXXX

# Central License Server
CENTRAL_LICENSE_URL=https://rim-license-server-production.up.railway.app

# Web Push Notifications (VAPID Keys)
# สร้างได้ด้วย: node -e "const c=require('crypto');const {publicKey,privateKey}=c.generateKeyPairSync('ec',{namedCurve:'prime256v1'});console.log(publicKey.export({type:'spki',format:'der'}).slice(-65).toString('base64url'),privateKey.export({type:'pkcs8',format:'der'}).slice(-32).toString('base64url'))"
VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:admin@rim-system.com

# Email Notifications (ถ้ายังไม่มีใส่ว่างไว้ก่อน)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
