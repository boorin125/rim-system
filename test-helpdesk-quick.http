# =========================================================
# HELP_DESK Quick Testing (15+ tests)
# =========================================================

### ===============================================
### 1. Login as Help Desk
### ===============================================
POST {{apiBase}}/auth/login
Content-Type: application/json

{
  "email": "helpdesk@rim.com",
  "password": "password123"
}

# Copy access_token to @tokenHelpDesk

### ===============================================
### INCIDENT OPERATIONS
### ===============================================

### 2. View All Incidents (Should Success ✅)
GET {{apiBase}}/incidents
Authorization: Bearer {{tokenHelpDesk}}

# Expected: 200 OK
# Should see ALL incidents (not filtered)

### 3. Create Incident (Should Success ✅) - PRIMARY FUNCTION!
POST {{apiBase}}/incidents
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "title": "Network switch failure at CentralWorld",
  "description": "Store network completely down. All POS terminals offline.",
  "category": "Network",
  "priority": "CRITICAL",
  "storeId": 2,
  "equipmentId": 4
}

# Expected: 201 Created
# Status: OPEN
# This is HELP_DESK's main responsibility!

### 4. View Created Incident
GET {{apiBase}}/incidents/INC-2025-0005
Authorization: Bearer {{tokenHelpDesk}}

# Expected: 200 OK
# Should see the incident we just created

### 5. Update Incident (Should Success ✅)
PATCH {{apiBase}}/incidents/INC-2025-0005
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "priority": "HIGH",
  "notes": "Updated priority after initial assessment"
}

# Expected: 200 OK
# Priority should change from CRITICAL to HIGH

### 6. Assign Incident to Technician (Should Success ✅)
POST {{apiBase}}/incidents/INC-2025-0005/assign
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "technicianId": 5
}

# Expected: 200 OK
# Status should change: OPEN → ASSIGNED
# assigneeId should be set to 5

### 7. Reassign Incident (Should Success ✅)
POST {{apiBase}}/incidents/INC-2025-0005/reassign
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "technicianId": 5
}

# Expected: 200 OK
# Status should reset to ASSIGNED

### 8. Close RESOLVED Incident (Should Success ✅) - PRIMARY FUNCTION!
# First, need to have a RESOLVED incident
# Use INC-2025-0001 which was resolved by TECHNICIAN

POST {{apiBase}}/incidents/INC-2025-0004/close
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "resolutionNote": "Verified repair. All tests passed.",
  "photoEvidence": "repair_complete_20251223.jpg"
}

# Expected: 200 OK
# Status should change: RESOLVED → CLOSED
# This is HELP_DESK's main responsibility!

### 9. Cancel Incident (Should Success ✅)
POST {{apiBase}}/incidents/INC-2025-0005/cancel
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "cancellationReason": "Duplicate incident - already reported as INC-2025-0004"
}

# Expected: 200 OK
# Status should change to CANCELLED

### 10. Accept Incident (Should Fail ❌)
# Login as Technician first to get incident in right state
POST {{apiBase}}/auth/login
Content-Type: application/json

{
  "email": "technician@rim.com",
  "password": "password123"
}

# Create new incident for this test
POST {{apiBase}}/incidents
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "title": "Test for Accept restriction",
  "description": "Testing HELP_DESK cannot accept",
  "category": "Hardware",
  "priority": "LOW",
  "storeId": 1
}

# Assign it
POST {{apiBase}}/incidents/INC-2025-0006/assign
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "technicianId": 5
}

# Try to accept (Should Fail)
POST {{apiBase}}/incidents/INC-2025-0006/accept
Authorization: Bearer {{tokenHelpDesk}}

# Expected: 403 Forbidden
# Only TECHNICIAN can accept

### 11. Resolve Incident (Should Fail ❌)
POST {{apiBase}}/incidents/INC-2025-0006/resolve
Authorization: Bearer {{tokenHelpDesk}}
Content-Type: application/json

{
  "resolutionNote": "Should fail"
}

# Expected: 403 Forbidden
# Only TECHNICIAN can resolve

