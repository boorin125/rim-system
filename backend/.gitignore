# RIM System - Git Ignore File

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================
# Environment Variables (CRITICAL!)
# ============================================
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
prisma/migrations/*_migration/
!prisma/migrations/migration_lock.toml

# ============================================
# Compiled Output
# ============================================
dist/
build/
*.js.map
*.d.ts.map

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.Spotlight-V100
.Trashes

# ============================================
# IDE & Editors
# ============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# Testing
# ============================================
coverage/
*.lcov
.nyc_output
lib-cov

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp
.cache/

# ============================================
# Build Files
# ============================================
*.tgz
*.zip
*.tar.gz

# ============================================
# Documentation (Generated)
# ============================================
docs/generated/

# ============================================
# Uploads & User Data (if any)
# ============================================
uploads/*
!uploads/.gitkeep

# ============================================
# Custom
# ============================================
# Test API files with tokens
test-api-private.http
*.http.private

# Backup files
*.backup
*.bak

# Local development files
.local/

# ============================================
# Keep These Files
# ============================================
!.gitkeep
!README.md
!LICENSE
!.env.example