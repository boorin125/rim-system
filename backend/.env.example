# ============================================
# RIM System - Environment Variables Template
# ============================================
# 
# IMPORTANT: 
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to git
#
# ============================================

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://rim_system:YOUR_PASSWORD@localhost:5432/rim_system"

# Database connection details (for reference)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rim_system
# DB_USER=rim_system
# DB_PASSWORD=YOUR_PASSWORD

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET="change-this-to-a-very-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV="development"

# ============================================
# API Configuration
# ============================================
API_PREFIX="api"

# ============================================
# CORS Configuration
# ============================================
# CORS_ORIGIN="http://localhost:3001"
# CORS_CREDENTIALS=true

# ============================================
# File Upload Configuration (if needed)
# ============================================
# MAX_FILE_SIZE=10485760  # 10MB in bytes
# UPLOAD_DIR="./uploads"

# ============================================
# Email Configuration
# ============================================
# For Gmail: Use App Password (not regular password)
# 1. Enable 2-Step Verification
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"

# ============================================
# SMS Configuration (future)
# ============================================
# SMS_API_KEY="your-sms-api-key"
# SMS_SENDER="RIM-System"

# ============================================
# Application Settings
# ============================================
# APP_NAME="RIM System"
# APP_URL="http://localhost:3000"

# ============================================
# Logging
# ============================================
# LOG_LEVEL="debug"
# LOG_DIR="./logs"

# ============================================
# Security
# ============================================
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW="15m"

# ============================================
# Company Settings (Example)
# ============================================
# COMPANY_NAME="Watsons Thailand"
# COMPANY_TIMEZONE="Asia/Bangkok"
# COMPANY_LOCALE="th"

# ============================================
# Feature Flags (future)
# ============================================
# FEATURE_KNOWLEDGE_BASE=false
# FEATURE_AUTO_ASSIGNMENT=false
# FEATURE_SMS_NOTIFICATIONS=false
# FEATURE_EMAIL_NOTIFICATIONS=false

# ============================================
# Development Only
# ============================================
# SWAGGER_ENABLED=true
# DEBUG_MODE=true

# ============================================
# Notes:
# ============================================
# 1. For production, generate strong JWT_SECRET:
#    openssl rand -base64 64
#
# 2. Use strong database password:
#    openssl rand -base64 32
#
# 3. Enable HTTPS in production
#
# 4. Review all settings before deployment
# ============================================

# Web Push (VAPID) - generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourcompany.com
