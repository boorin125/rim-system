generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          Int                          @id @default(autoincrement())
  username                    String                       @unique
  email                       String                       @unique
  password                    String
  firstName                   String?                      @map("first_name")
  lastName                    String?                      @map("last_name")
  phone                       String?
  department                  String?                      @map("department")
  technicianType              TechnicianType?              @map("technician_type")
  serviceCenter               String?                      @map("service_center")
  responsibleProvinces        String[]                     @default([]) @map("responsible_provinces")
  address                     String?                      @db.Text
  avatarPath                  String?                      @map("avatar_path")
  bankBookPath                String?                      @map("bank_book_path")
  idCardPath                  String?                      @map("id_card_path")
  signaturePath               String?                      @map("signature_path")
  cumulativeRating            Float                        @default(5.0) @map("cumulative_rating")
  roles                       UserRoleAssignment[]
  status                      UserStatus                   @default(PENDING)
  isProtected                 Boolean                      @default(false) @map("is_protected")
  twoFactorEnabled            Boolean                      @default(false) @map("two_factor_enabled")
  twoFactorSecret             String?                      @map("two_factor_secret")
  failedLoginAttempts         Int                          @default(0) @map("failed_login_attempts")
  lockedUntil                 DateTime?                    @map("locked_until")
  lastLogin                   DateTime?                    @map("last_login")
  lastPasswordChange          DateTime?                    @map("last_password_change")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  createdBy                   Int?                         @map("created_by")
  incidentsCreated            Incident[]                   @relation("IncidentCreatedBy")
  incidentsAssigned           Incident[]                   @relation("IncidentAssignedTo")
  equipmentLogs               EquipmentLog[]
  resolvedIncidents           Incident[]                   @relation("ResolvedBy")
  techConfirmedIncidents      Incident[]                   @relation("TechConfirmedBy")
  confirmedIncidents          Incident[]                   @relation("ConfirmedBy")
  reopenedIncidents           Incident[]                   @relation("LastReopenedBy")
  respondedIncidents          Incident[]                   @relation("RespondedBy")
  comments                    Comment[]
  incidentHistory             IncidentHistory[]
  notifications               Notification[]
  storeDeleteRequests         StoreDeleteRequest[]         @relation("StoreDeleteRequester")
  approvedDeleteRequests      StoreDeleteRequest[]         @relation("StoreDeleteApprover")
  equipmentRetirementRequests EquipmentRetirementRequest[] @relation("EquipmentRetireRequester")
  approvedRetirementRequests  EquipmentRetirementRequest[] @relation("EquipmentRetireApprover")
  passwordResetTokens         PasswordResetToken[]
  refreshTokens               RefreshToken[]

  // Multi-technician assignment
  incidentAssignments IncidentAssignee[] @relation("IncidentAssignees")

  // Reassignment relations
  reassignmentsFrom IncidentReassignment[] @relation("ReassignmentFrom")
  reassignmentsTo   IncidentReassignment[] @relation("ReassignmentTo")
  reassignmentsBy   IncidentReassignment[] @relation("ReassignmentBy")

  // Rating relations
  ratingsGiven IncidentRating[]

  // Performance relations
  performanceScores       TechnicianPerformanceScore[] @relation("PerformanceScore")
  performanceCalculatedBy TechnicianPerformanceScore[] @relation("PerformanceCalculatedBy")

  // Outsource Marketplace relations
  outsourceJobsPosted              OutsourceJob[] @relation("OutsourceJobPostedBy")
  outsourceJobsApproved            OutsourceJob[] @relation("OutsourceJobApprovedBy")
  outsourceJobsAwarded             OutsourceJob[] @relation("OutsourceJobAwardedTo")
  outsourceJobsAwardedBy           OutsourceJob[] @relation("OutsourceJobAwardedBy")
  outsourceJobsVerified            OutsourceJob[] @relation("OutsourceJobVerifiedBy")
  outsourceJobsPaid                OutsourceJob[] @relation("OutsourceJobPaidBy")
  outsourceJobsCancelRequested     OutsourceJob[] @relation("OutsourceJobCancelRequestedBy")
  outsourceJobsCancelConfirmed     OutsourceJob[] @relation("OutsourceJobCancelConfirmedBy")
  outsourceJobsSparePartsConfirmed OutsourceJob[] @relation("OutsourceJobSparePartsConfirmedBy")
  outsourceJobsDocumentsReceived   OutsourceJob[] @relation("OutsourceJobDocumentsReceivedBy")
  outsourceBids                    OutsourceBid[] @relation("OutsourceBidTechnician")

  // Knowledge Base relations
  kbArticlesAuthored KnowledgeArticle[]         @relation("ArticleAuthor")
  kbArticlesEdited   KnowledgeArticle[]         @relation("ArticleLastEditor")
  kbArticleFeedbacks KnowledgeArticleFeedback[]
  kbArticleUsages    KnowledgeArticleUsage[]

  // Backup & Restore relations
  backupJobsCreated      BackupJob[]      @relation("BackupCreatedBy")
  restoreJobsCreated     RestoreJob[]     @relation("RestoreCreatedBy")
  backupSchedulesCreated BackupSchedule[] @relation("ScheduleCreatedBy")

  // Audit Trail relations
  auditLogs AuditLog[]

  // SLA Defense relations
  slaDefensesSubmitted SlaDefense[] @relation("SlaDefenseTechnician")
  slaDefensesReviewed  SlaDefense[] @relation("SlaDefenseReviewer")

  // Version management
  appliedVersions AppVersion[]

  @@map("users")
}

// User Role Assignment (Many-to-Many)
model UserRoleAssignment {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_role_assignments")
}

model Store {
  id               Int                  @id @default(autoincrement())
  storeCode        String               @map("store_code")
  name             String
  company          String?
  storeType        StoreType            @default(PERMANENT) @map("store_type")
  address          String?
  province         String?
  district         String?
  subDistrict      String?              @map("sub_district")
  postalCode       String?              @map("postal_code")
  area             String?
  slaRegion        SlaRegion            @default(BANGKOK_METRO) @map("sla_region") // พื้นที่สำหรับคำนวณ SLA
  serviceCenter    String?              @map("service_center")
  latitude         Float?
  longitude        Float?
  phone            String?
  email            String?
  googleMapLink    String?              @map("google_map_link")
  circuitId        String?              @map("circuit_id")
  routerIp         String?              @map("router_ip")
  switchIp         String?              @map("switch_ip")
  accessPointIp    String?              @map("access_point_ip")
  pcServerIp       String?              @map("pc_server_ip")
  pcPrinterIp      String?              @map("pc_printer_ip")
  pmcComputerIp    String?              @map("pmc_computer_ip")
  sbsComputerIp    String?              @map("sbs_computer_ip")
  vatComputerIp    String?              @map("vat_computer_ip")
  posIp            String?              @map("pos_ip")
  edcIp            String?              @map("edc_ip")
  scoIp            String?              @map("sco_ip")
  peopleCounterIp  String?              @map("people_counter_ip")
  digitalTvIp      String?              @map("digital_tv_ip")
  timeAttendanceIp String?              @map("time_attendance_ip")
  cctvIp           String?              @map("cctv_ip")
  mondayOpen       String?              @map("monday_open")
  mondayClose      String?              @map("monday_close")
  tuesdayOpen      String?              @map("tuesday_open")
  tuesdayClose     String?              @map("tuesday_close")
  wednesdayOpen    String?              @map("wednesday_open")
  wednesdayClose   String?              @map("wednesday_close")
  thursdayOpen     String?              @map("thursday_open")
  thursdayClose    String?              @map("thursday_close")
  fridayOpen       String?              @map("friday_open")
  fridayClose      String?              @map("friday_close")
  saturdayOpen     String?              @map("saturday_open")
  saturdayClose    String?              @map("saturday_close")
  sundayOpen       String?              @map("sunday_open")
  sundayClose      String?              @map("sunday_close")
  holidayOpen      String?              @map("holiday_open")
  holidayClose     String?              @map("holiday_close")
  openDate         DateTime?            @map("open_date")
  closeDate        DateTime?            @map("close_date")
  storeStatus      StoreStatus          @default(ACTIVE) @map("store_status")
  layoutImagePath  String?              @map("layout_image_path")
  ipRangeImagePath String?              @map("ip_range_image_path")
  notes            String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  equipment        Equipment[]
  incidents        Incident[]
  deleteRequests   StoreDeleteRequest[]
  pmRecords        PmRecord[]
  lastPmAt         DateTime?            @map("last_pm_at")

  @@index([storeCode])
  @@index([company])
  @@index([storeStatus])
  @@index([province])
  @@map("stores")
}

model Equipment {
  id                 Int                          @id @default(autoincrement())
  serialNumber       String                       @unique @map("serial_number")
  name               String // ชื่ออุปกรณ์รวมตำแหน่ง เช่น "POS#1 Printer"
  category           String
  brand              String?
  model              String?
  purchaseDate       DateTime?                    @map("purchase_date")
  warrantyExpiry     DateTime?                    @map("warranty_expiry")
  ipAddress          String?                      @map("ip_address")
  imagePath          String?                      @map("image_path")
  status             EquipmentStatus              @default(ACTIVE)
  storeId            Int                          @map("store_id")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")
  store              Store                        @relation(fields: [storeId], references: [id])
  incidents          Incident[]
  logs               EquipmentLog[]
  retirementRequests EquipmentRetirementRequest[]

  // Spare parts tracking - อุปกรณ์ที่ถูกเปลี่ยน
  replacedByParts    SparePart[]         @relation("OldEquipment") // ถูกถอดออกจาก Incident
  replacingParts     SparePart[]         @relation("NewEquipment") // ถูกใส่เข้าไปใน Incident
  componentParts     SparePart[]         @relation("ParentEquipment") // ชิ้นส่วนที่ถูกเปลี่ยนภายในอุปกรณ์นี้
  pmEquipmentRecords PmEquipmentRecord[]

  @@map("equipment")
}

model EquipmentLog {
  id          Int                @id @default(autoincrement())
  equipmentId Int                @map("equipment_id")
  action      EquipmentLogAction
  description String
  changedBy   Int                @map("changed_by")
  oldValue    String?            @map("old_value")
  newValue    String?            @map("new_value")
  createdAt   DateTime           @default(now()) @map("created_at")
  equipment   Equipment          @relation(fields: [equipmentId], references: [id])
  user        User               @relation(fields: [changedBy], references: [id])

  @@index([equipmentId])
  @@index([changedBy])
  @@index([createdAt])
  @@map("equipment_logs")
}

model EquipmentRetirementRequest {
  id           Int       @id @default(autoincrement())
  equipmentId  Int       @map("equipment_id")
  equipment    Equipment @relation(fields: [equipmentId], references: [id])
  requestedBy  Int       @map("requested_by")
  requester    User      @relation("EquipmentRetireRequester", fields: [requestedBy], references: [id])
  reason       String
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy   Int?      @map("approved_by")
  approver     User?     @relation("EquipmentRetireApprover", fields: [approvedBy], references: [id])
  approvalNote String?   @map("approval_note")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([equipmentId])
  @@index([requestedBy])
  @@index([status])
  @@map("equipment_retirement_requests")
}

model Incident {
  id                String          @id
  ticketNumber      String          @unique @map("ticket_number")
  title             String
  description       String
  category          String?
  jobType           String?         @map("job_type")
  priority          Priority
  status            IncidentStatus  @default(OPEN)
  incidentType      IncidentType    @default(NORMAL) @map("incident_type")
  resolutionType    ResolutionType? @map("resolution_type")
  storeId           Int             @map("store_id")
  storeName         String?         @map("store_name") // Stored for historical reference when store is deleted
  storeCode         String?         @map("store_code") // Stored for historical reference when store is deleted
  equipmentId       Int?            @map("equipment_id")
  equipmentIds      Int[]           @default([]) @map("equipment_ids")
  reportedBy        Int             @map("reported_by")
  createdById       Int             @map("created_by_id")
  assigneeId        Int?            @map("assignee_id")
  relatedIncidentId String?         @map("related_incident_id")
  slaDeadline       DateTime?       @map("sla_deadline")
  notes             String?
  incidentDate      DateTime?       @map("incident_date") // วันที่ลูกค้าแจ้ง (อาจก่อน createdAt)
  scheduledAt       DateTime?       @map("scheduled_at") // วันเวลานัดเข้าดำเนินการ (Project/Adhoc)
  scheduledReason   String?         @map("scheduled_reason") // เหตุผลการระบุเวลาเข้าดำเนินการ
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Technician Workflow Fields
  checkInAt             DateTime? @map("check_in_at")
  checkInLatitude       Float?    @map("check_in_latitude") // GPS latitude at check-in
  checkInLongitude      Float?    @map("check_in_longitude") // GPS longitude at check-in
  cancelledAfterCheckin Boolean   @default(false) @map("cancelled_after_checkin")
  beforePhotos          String[]  @default([]) @map("before_photos")

  resolvedAt         DateTime? @map("resolved_at")
  resolvedById       Int?      @map("resolved_by_id")
  resolutionNote     String?   @map("resolution_note")
  usedSpareParts     Boolean   @default(false) @map("used_spare_parts")
  afterPhotos        String[]  @default([]) @map("after_photos")
  signedReportPhotos String[]  @default([]) @map("signed_report_photos")

  // Technician Confirm Resolve (gate before helpdesk notification)
  techConfirmedAt   DateTime? @map("tech_confirmed_at")
  techConfirmedById Int?      @map("tech_confirmed_by_id")

  confirmedAt   DateTime? @map("confirmed_at")
  confirmedById Int?      @map("confirmed_by_id")

  // Reopen Tracking Fields
  reopenCount      Int       @default(0) @map("reopen_count")
  lastReopenedAt   DateTime? @map("last_reopened_at")
  lastReopenedById Int?      @map("last_reopened_by_id")
  reopenReason     String?   @map("reopen_reason")

  // Technician Response Fields (before onsite)
  respondedAt          DateTime? @map("responded_at")
  respondedById        Int?      @map("responded_by_id")
  estimatedArrivalTime DateTime? @map("estimated_arrival_time")
  responseMessage      String?   @map("response_message") @db.Text
  respondedBy          User?     @relation("RespondedBy", fields: [respondedById], references: [id])

  // Rating Token (Public Link for customer rating)
  ratingToken          String?   @unique @map("rating_token")
  ratingTokenCreatedAt DateTime? @map("rating_token_created_at")
  ratingTokenExpiresAt DateTime? @map("rating_token_expires_at")
  ratingEmailSentAt    DateTime? @map("rating_email_sent_at")

  // Service Report Token (Public Link for service report / signature)
  serviceReportToken          String?   @unique @map("service_report_token")
  serviceReportTokenCreatedAt DateTime? @map("service_report_token_created_at")
  serviceReportTokenExpiresAt DateTime? @map("service_report_token_expires_at")

  // Customer Signature
  customerSignature     String?   @map("customer_signature") @db.Text
  customerSignatureName String?   @map("customer_signature_name")
  customerSignedAt      DateTime? @map("customer_signed_at")

  // Relations
  createdBy       User                    @relation("IncidentCreatedBy", fields: [createdById], references: [id])
  assignee        User?                   @relation("IncidentAssignedTo", fields: [assigneeId], references: [id])
  resolvedBy      User?                   @relation("ResolvedBy", fields: [resolvedById], references: [id])
  techConfirmedBy User?                   @relation("TechConfirmedBy", fields: [techConfirmedById], references: [id])
  confirmedBy     User?                   @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  lastReopenedBy  User?                   @relation("LastReopenedBy", fields: [lastReopenedById], references: [id])
  equipment       Equipment?              @relation(fields: [equipmentId], references: [id])
  store           Store                   @relation(fields: [storeId], references: [id])
  relatedIncident Incident?               @relation("RelatedIncidents", fields: [relatedIncidentId], references: [id])
  childIncidents  Incident[]              @relation("RelatedIncidents")
  spareParts      SparePart[]
  comments        Comment[]
  history         IncidentHistory[]
  notifications   Notification[]
  reassignments   IncidentReassignment[]
  assignees       IncidentAssignee[]
  rating          IncidentRating?
  outsourceJobs   OutsourceJob[]
  kbArticleUsages KnowledgeArticleUsage[]
  slaDefenses     SlaDefense[]
  pmRecord        PmRecord?

  @@index([ratingToken])
  @@map("incidents")
}

model SparePart {
  id         Int    @id @default(autoincrement())
  incidentId String @map("incident_id")

  // Repair Type - ประเภทการซ่อม
  repairType RepairType @default(EQUIPMENT_REPLACEMENT) @map("repair_type")

  // For EQUIPMENT_REPLACEMENT - เปลี่ยนอุปกรณ์ทั้งตัว
  deviceName  String  @map("device_name")
  oldSerialNo String  @map("old_serial_no")
  newSerialNo String  @map("new_serial_no")
  newBrand    String? @map("new_brand") // ยี่ห้ออุปกรณ์ใหม่ที่ใส่เข้าไป
  newModel    String? @map("new_model") // รุ่นอุปกรณ์ใหม่ที่ใส่เข้าไป

  // For COMPONENT_REPLACEMENT - เปลี่ยนเฉพาะชิ้นส่วนภายใน (เช่น แบตเตอรี่ใน UPS)
  componentName      String? @map("component_name") // ชื่อชิ้นส่วน เช่น "Battery", "Power Supply"
  oldComponentSerial String? @map("old_component_serial") // Serial เดิมของชิ้นส่วน
  newComponentSerial String? @map("new_component_serial") // Serial ใหม่ของชิ้นส่วน
  parentEquipmentId  Int?    @map("parent_equipment_id") // อุปกรณ์หลักที่ชิ้นส่วนอยู่ใน

  notes String?

  // Equipment tracking - เชื่อมโยงกับ Equipment ที่ถูกเปลี่ยน (สำหรับ EQUIPMENT_REPLACEMENT)
  oldEquipmentId Int? @map("old_equipment_id") // อุปกรณ์เดิมที่ถูกถอดออก
  newEquipmentId Int? @map("new_equipment_id") // อุปกรณ์ใหม่ที่ใส่เข้าไป

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  incident        Incident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  oldEquipment    Equipment? @relation("OldEquipment", fields: [oldEquipmentId], references: [id])
  newEquipment    Equipment? @relation("NewEquipment", fields: [newEquipmentId], references: [id])
  parentEquipment Equipment? @relation("ParentEquipment", fields: [parentEquipmentId], references: [id])

  @@index([oldEquipmentId])
  @@index([newEquipmentId])
  @@index([parentEquipmentId])
  @@map("spare_parts")
}

model Comment {
  id         Int      @id @default(autoincrement())
  incidentId String   @map("incident_id")
  userId     Int      @map("user_id")
  content    String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([userId])
  @@map("comments")
}

model IncidentHistory {
  id         Int             @id @default(autoincrement())
  incidentId String          @map("incident_id")
  userId     Int?            @map("user_id")
  action     IncidentAction
  oldStatus  IncidentStatus? @map("old_status")
  newStatus  IncidentStatus? @map("new_status")
  details    String?         @db.Text
  createdAt  DateTime        @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([incidentId])
  @@index([userId])
  @@index([createdAt])
  @@map("incident_history")
}

model Notification {
  id         Int              @id @default(autoincrement())
  userId     Int              @map("user_id")
  type       NotificationType
  title      String
  message    String           @db.Text
  incidentId String?          @map("incident_id")
  link       String?
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([incidentId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum UserRole {
  SUPER_ADMIN
  IT_MANAGER
  FINANCE_ADMIN
  HELP_DESK
  SUPERVISOR
  TECHNICIAN
  END_USER
  READ_ONLY
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

enum TechnicianType {
  INSOURCE
  OUTSOURCE
}

enum StoreType {
  PERMANENT
  POP_UP
  SEASONAL
}

enum StoreStatus {
  ACTIVE
  TEMPORARILY_CLOSED
  PERMANENTLY_CLOSED
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum EquipmentCategory {
  NETWORK
  COMPUTER
  POS
  PRINTER
  ROUTER
  SWITCH
  CCTV
  OTHER
}

enum EquipmentLogAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  TRANSFERRED
  RETIRED
  WARRANTY_UPDATED
  MAINTENANCE_SCHEDULED
  MAINTENANCE_COMPLETED
  REPLACED_OUT // ถูกถอดออกจาก Incident (อุปกรณ์เดิม)
  REPLACED_IN // ถูกใส่เข้าไปใน Incident (อุปกรณ์ใหม่)
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// ประเภทการซ่อม - Repair Type for Spare Parts
enum RepairType {
  EQUIPMENT_REPLACEMENT // เปลี่ยนอุปกรณ์ทั้งตัว
  COMPONENT_REPLACEMENT // เปลี่ยนเฉพาะชิ้นส่วนภายใน (เช่น Battery, Power Supply)
}

enum IncidentStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
  CANCELLED
  OUTSOURCED
}

enum SlaDefenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IncidentAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  REASSIGNED
  UNASSIGNED
  TECHNICIAN_RESPONDED
  CHECKED_IN
  RESOLVED
  RESOLUTION_UPDATED
  TECH_CONFIRMED
  CONFIRMED
  CLOSED
  REOPENED
  CANCELLED
  COMMENTED
  DELETED
  RETURN_JOB_CREATED
  DIRECT_CLOSED
  REQUESTED_ONSITE
}

enum IncidentType {
  NORMAL
  RETURN_EQUIPMENT
  FOLLOW_UP
}

enum ResolutionType {
  PHONE_SUPPORT
  REMOTE_SUPPORT
  ONSITE
}

enum NotificationType {
  INCIDENT_CREATED
  INCIDENT_ASSIGNED
  INCIDENT_REASSIGNED
  INCIDENT_RESPONDED
  INCIDENT_CHECKED_IN
  INCIDENT_RESOLVED
  INCIDENT_CONFIRMED
  INCIDENT_REOPENED
  INCIDENT_CANCELLED
  COMMENT_ADDED
  STATUS_CHANGED
  SYSTEM_ALERT
  SLA_WARNING
  SLA_BREACH
  NEW_USER_REGISTERED
}

// Password Reset Tokens
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  used      Boolean   @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// Refresh Tokens for JWT authentication
model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
