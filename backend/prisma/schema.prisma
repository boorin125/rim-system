// SLA Region - พื้นที่สำหรับคำนวณ SLA
enum SlaRegion {
  BANGKOK_METRO // กรุงเทพฯ และปริมณฑล
  PROVINCIAL // ต่างจังหวัด
}

model SlaConfig {
  id                       Int      @id @default(autoincrement())
