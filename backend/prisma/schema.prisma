// ========================================
// TECHNICIAN PERFORMANCE GRADING SYSTEM (Feature 14)
// ประเมินผลการทำงานช่างเทคนิคอัตโนมัติ
// ========================================

model TechnicianPerformanceScore {
  id           Int @id @default(autoincrement())
  technicianId Int @map("technician_id")

  // Period
  period    String // 'YYYY-MM' format
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  // Core Metrics (raw data + score)
  slaCompliance Decimal? @map("sla_compliance") @db.Decimal(5, 2)
  slaScore      Decimal? @map("sla_score") @db.Decimal(5, 2)

  workVolume       Int?     @map("work_volume")
  workVolumeTarget Int?     @map("work_volume_target")
  workVolumeScore  Decimal? @map("work_volume_score") @db.Decimal(5, 2)

  avgResolutionTime      Decimal? @map("avg_resolution_time") @db.Decimal(8, 2) // hours
  resolutionTimeStandard Decimal? @map("resolution_time_standard") @db.Decimal(8, 2)
  resolutionTimeScore    Decimal? @map("resolution_time_score") @db.Decimal(5, 2)

  avgResponseTime      Decimal? @map("avg_response_time") @db.Decimal(8, 2) // minutes
  responseTimeStandard Decimal? @map("response_time_standard") @db.Decimal(8, 2)
  responseTimeScore    Decimal? @map("response_time_score") @db.Decimal(5, 2)

  firstTimeFixRate  Decimal? @map("first_time_fix_rate") @db.Decimal(5, 2)
  firstTimeFixScore Decimal? @map("first_time_fix_score") @db.Decimal(5, 2)

  reopenRate  Decimal? @map("reopen_rate") @db.Decimal(5, 2)
  reopenScore Decimal? @map("reopen_score") @db.Decimal(5, 2)

  avgCustomerRating         Decimal? @map("avg_customer_rating") @db.Decimal(3, 2)
  totalRatings              Int?     @map("total_ratings")
  customerSatisfactionScore Decimal? @map("customer_satisfaction_score") @db.Decimal(5, 2)

  // Bonus Points
  kbUsageRate  Decimal? @map("kb_usage_rate") @db.Decimal(5, 2)
  kbUsageBonus Decimal? @map("kb_usage_bonus") @db.Decimal(5, 2)

  equipmentDamageCount   Int?     @map("equipment_damage_count")
  equipmentDamagePenalty Decimal? @map("equipment_damage_penalty") @db.Decimal(5, 2)

  availabilityRate  Decimal? @map("availability_rate") @db.Decimal(5, 2)
  availabilityBonus Decimal? @map("availability_bonus") @db.Decimal(5, 2)

  documentationQualityRate Decimal? @map("documentation_quality_rate") @db.Decimal(5, 2)
  documentationBonus       Decimal? @map("documentation_bonus") @db.Decimal(5, 2)

  totalBonusPoints Decimal? @map("total_bonus_points") @db.Decimal(5, 2)

  // Final Score & Grade
  totalScore       Decimal? @map("total_score") @db.Decimal(5, 2) // 0-100+
  grade            String?  @db.VarChar(2) // 'A+', 'A', 'B+', 'B', 'C+', 'C', 'D', 'F'
  gradeDescription String?  @map("grade_description") @db.VarChar(50)

  // Ranking
  teamRanking      Int? @map("team_ranking")
  totalTechnicians Int? @map("total_technicians")

  // Comparison
  teamAvgScore      Decimal? @map("team_avg_score") @db.Decimal(5, 2)
  topPerformerScore Decimal? @map("top_performer_score") @db.Decimal(5, 2)

  // Metadata
  isCalculated   Boolean   @default(false) @map("is_calculated")
  calculatedAt   DateTime? @map("calculated_at")
  calculatedById Int?      @map("calculated_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  technician   User  @relation("PerformanceScore", fields: [technicianId], references: [id], onDelete: Cascade)
  calculatedBy User? @relation("PerformanceCalculatedBy", fields: [calculatedById], references: [id])

  @@unique([technicianId, period])
  @@index([technicianId, period])
  @@index([period])
  @@index([grade])
  @@index([teamRanking])
  @@index([totalScore(sort: Desc)])
  @@map("technician_performance_scores")
}

// ========================================
// OUTSOURCE MARKETPLACE SYSTEM (Feature 7)
// ระบบตลาดจ้างช่างภายนอก
// ========================================

model OutsourceJob {
  id         Int    @id @default(autoincrement())
  incidentId String @map("incident_id")
  jobCode    String @unique @map("job_code") // OUT-YYYYMMDD-XXXX

  // Job Details
  title          String
  description    String   @db.Text
  requirements   String?  @db.Text // ข้อกำหนดพิเศษ
  location       String?  @db.Text // สถานที่ทำงาน
  estimatedHours Decimal? @map("estimated_hours") @db.Decimal(5, 2)

  // Pricing
  budgetMin   Decimal? @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal? @map("budget_max") @db.Decimal(10, 2)
  agreedPrice Decimal? @map("agreed_price") @db.Decimal(10, 2)

  // Deadline
  deadline     DateTime?
  urgencyLevel UrgencyLevel @default(NORMAL) @map("urgency_level")

  // Job Type & Status
  jobType String             @default("MARKETPLACE") @map("job_type") // MARKETPLACE | DIRECT_ASSIGN
  status  OutsourceJobStatus @default(PENDING_APPROVAL)

  // Approval (IT Manager)
  approvalStatus  String    @default("PENDING") @map("approval_status") // PENDING | APPROVED | REJECTED
  approvedById    Int?      @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  // Posted By (IT Manager / Help Desk)
  postedById Int      @map("posted_by_id")
  postedAt   DateTime @default(now()) @map("posted_at")

  // Awarded To
  awardedToId           Int?            @map("awarded_to_id")
  awardedAt             DateTime?       @map("awarded_at")
  awardedById           Int?            @map("awarded_by_id")
  awardNotes            String?         @map("award_notes") @db.Text
  technicianTypeAtAward TechnicianType? @map("technician_type_at_award")

  // Completion
  completedAt      DateTime? @map("completed_at")
  completionNotes  String?   @map("completion_notes") @db.Text
  completionPhotos String[]  @default([]) @map("completion_photos")

  // Verification
  verifiedAt         DateTime?           @map("verified_at")
  verifiedById       Int?                @map("verified_by_id")
  verificationNotes  String?             @map("verification_notes") @db.Text
  verificationStatus VerificationStatus? @map("verification_status")

  // Payment
  paymentStatus    PaymentStatus @default(UNPAID) @map("payment_status")
  paymentAmount    Decimal?      @map("payment_amount") @db.Decimal(10, 2)
  withholdingTax   Decimal?      @map("withholding_tax") @db.Decimal(10, 2)
  netPaymentAmount Decimal?      @map("net_payment_amount") @db.Decimal(10, 2)
  paymentSlipPath  String?       @map("payment_slip_path")
  paymentNote      String?       @map("payment_note") @db.Text
  paidAt           DateTime?     @map("paid_at")
  paidById         Int?          @map("paid_by_id")

  // Rating
  technicianRating  Int?    @map("technician_rating") @db.SmallInt
  technicianComment String? @map("technician_comment") @db.Text
  customerRating    Int?    @map("customer_rating") @db.SmallInt
  customerComment   String? @map("customer_comment") @db.Text

  // Document Submission (Outsource ส่งเอกสาร)
  documentSlipPath      String?   @map("document_slip_path")
  documentWorkOrderPath String?   @map("document_work_order_path")
  documentPhotos        String[]  @default([]) @map("document_photos")
  shippingCost          Decimal?  @map("shipping_cost") @db.Decimal(10, 2)
  documentSubmittedAt   DateTime? @map("document_submitted_at")
  documentReviewNotes   Json?     @default("[]") @map("document_review_notes")

  // Finance Confirmation
  sparePartsReturned      Boolean   @default(false) @map("spare_parts_returned")
  sparePartsConfirmedAt   DateTime? @map("spare_parts_confirmed_at")
  sparePartsConfirmedById Int?      @map("spare_parts_confirmed_by_id")
  documentsReceivedAt     DateTime? @map("documents_received_at")
  documentsReceivedById   Int?      @map("documents_received_by_id")

  // Cancellation
  cancellationReason        String?   @map("cancellation_reason") @db.Text
  cancellationRequestedAt   DateTime? @map("cancellation_requested_at")
  cancellationRequestedById Int?      @map("cancellation_requested_by_id")
  cancellationConfirmedAt   DateTime? @map("cancellation_confirmed_at")
  cancellationConfirmedById Int?      @map("cancellation_confirmed_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  incident                Incident?      @relation(fields: [incidentId], references: [id])
  postedBy                User           @relation("OutsourceJobPostedBy", fields: [postedById], references: [id])
  approvedBy              User?          @relation("OutsourceJobApprovedBy", fields: [approvedById], references: [id])
  awardedTo               User?          @relation("OutsourceJobAwardedTo", fields: [awardedToId], references: [id])
  awardedBy               User?          @relation("OutsourceJobAwardedBy", fields: [awardedById], references: [id])
  verifiedBy              User?          @relation("OutsourceJobVerifiedBy", fields: [verifiedById], references: [id])
  paidBy                  User?          @relation("OutsourceJobPaidBy", fields: [paidById], references: [id])
  cancellationRequestedBy User?          @relation("OutsourceJobCancelRequestedBy", fields: [cancellationRequestedById], references: [id])
  cancellationConfirmedBy User?          @relation("OutsourceJobCancelConfirmedBy", fields: [cancellationConfirmedById], references: [id])
  sparePartsConfirmedBy   User?          @relation("OutsourceJobSparePartsConfirmedBy", fields: [sparePartsConfirmedById], references: [id])
  documentsReceivedBy     User?          @relation("OutsourceJobDocumentsReceivedBy", fields: [documentsReceivedById], references: [id])
  bids                    OutsourceBid[]

  @@index([incidentId])
  @@index([status])
  @@index([postedById])
  @@index([awardedToId])
  @@index([deadline])
  @@index([postedAt])
  @@map("outsource_jobs")
}

model OutsourceBid {
  id           Int @id @default(autoincrement())
  jobId        Int @map("job_id")
  technicianId Int @map("technician_id")

  // Bid Details
  proposedPrice     Decimal   @map("proposed_price") @db.Decimal(10, 2)
  estimatedHours    Decimal?  @map("estimated_hours") @db.Decimal(5, 2)
  proposedStartDate DateTime? @map("proposed_start_date")
  message           String?   @db.Text
  attachments       String[]  @default([])

  // Status
  status          BidStatus @default(PENDING)
  rejectionReason String?   @map("rejection_reason") @db.Text

  // Timestamps
  submittedAt DateTime  @default(now()) @map("submitted_at")
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  job        OutsourceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  technician User         @relation("OutsourceBidTechnician", fields: [technicianId], references: [id])

  @@unique([jobId, technicianId])
  @@index([jobId])
  @@index([technicianId])
  @@index([status])
  @@index([submittedAt])
  @@map("outsource_bids")
}

enum OutsourceJobStatus {
  DRAFT // ร่าง
  PENDING_APPROVAL // รอ IT Manager อนุมัติ
  OPEN // เปิดรับเสนอราคา
  PENDING_CANCEL // รอ Outsource ยืนยันยกเลิก
  BIDDING_CLOSED // ปิดรับเสนอราคา
  AWARDED // มอบหมายงานแล้ว
  IN_PROGRESS // กำลังดำเนินการ
  COMPLETED // ช่างทำเสร็จ รอส่งเอกสาร
  DOCUMENT_SUBMITTED // ส่งเอกสารแล้ว รอ Finance ตรวจรับ
  VERIFIED // ตรวจสอบผ่าน
  REJECTED // ตรวจสอบไม่ผ่าน ต้องแก้ไข
  PAID // จ่ายเงินแล้ว
  CANCELLED // ยกเลิก
}

enum UrgencyLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum BidStatus {
  PENDING // รอพิจารณา
  SHORTLISTED // อยู่ในรายการพิจารณา
  ACCEPTED // ได้รับเลือก
  REJECTED // ไม่ได้รับเลือก
  WITHDRAWN // ถอนข้อเสนอ
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum PaymentStatus {
  UNPAID
  PENDING_APPROVAL
  APPROVED
  PAID
  DISPUTED
}

// ========================================
// KNOWLEDGE BASE SYSTEM (Feature 12)
// ระบบฐานความรู้และ FAQ
// ========================================

model KnowledgeCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  icon        String? // Icon name
  color       String? // Color hex
  parentId    Int?     @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   KnowledgeCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children KnowledgeCategory[] @relation("CategoryHierarchy")
  articles KnowledgeArticle[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("knowledge_categories")
}

model KnowledgeArticle {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("category_id")
  title      String
  slug       String   @unique
  summary    String?  @db.Text
  content    String   @db.Text // Markdown content
  keywords   String[] @default([]) // Search keywords

  // Visibility
  isPublic    Boolean   @default(true) @map("is_public") // Public to all users
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")

  // Authorship
  authorId       Int  @map("author_id")
  lastEditedById Int? @map("last_edited_by_id")

  // Stats
  viewCount       Int @default(0) @map("view_count")
  helpfulCount    Int @default(0) @map("helpful_count")
  notHelpfulCount Int @default(0) @map("not_helpful_count")

  // Related
  relatedArticleIds Int[] @default([]) @map("related_article_ids")

  // Versioning
  version Int @default(1)

  // Attachments
  attachments String[] @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category     KnowledgeCategory          @relation(fields: [categoryId], references: [id])
  author       User                       @relation("ArticleAuthor", fields: [authorId], references: [id])
  lastEditedBy User?                      @relation("ArticleLastEditor", fields: [lastEditedById], references: [id])
  feedbacks    KnowledgeArticleFeedback[]
  usageHistory KnowledgeArticleUsage[]

  @@index([categoryId])
  @@index([authorId])
  @@index([isPublished])
  @@index([viewCount(sort: Desc)])
  @@index([helpfulCount(sort: Desc)])
  @@map("knowledge_articles")
}

model KnowledgeArticleFeedback {
  id        Int      @id @default(autoincrement())
  articleId Int      @map("article_id")
  userId    Int?     @map("user_id")
  isHelpful Boolean  @map("is_helpful")
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, userId])
  @@index([articleId])
  @@index([userId])
  @@map("knowledge_article_feedbacks")
}

model KnowledgeArticleUsage {
  id         Int         @id @default(autoincrement())
  articleId  Int         @map("article_id")
  incidentId String?     @map("incident_id")
  usedById   Int         @map("used_by_id")
  usageType  KBUsageType @default(VIEWED) @map("usage_type")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")

  article  KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  usedBy   User             @relation(fields: [usedById], references: [id])
  incident Incident?        @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@index([incidentId])
  @@index([usedById])
  @@index([createdAt])
  @@map("knowledge_article_usages")
}

enum KBUsageType {
  VIEWED // แค่ดู
  APPLIED // นำไปใช้แก้ปัญหา
  SHARED // แชร์ให้ผู้อื่น
  REFERENCED // อ้างอิงใน Incident
}

// ========================================
// BACKUP & RESTORE SYSTEM (Feature 13)
// ระบบสำรองและกู้คืนข้อมูล
// ========================================

model BackupJob {
  id         Int     @id @default(autoincrement())
  jobCode    String  @unique @map("job_code") // BKP-YYYYMMDD-HHMMSS
  customName String? @map("custom_name")

  // Backup Configuration
  backupType   BackupType  @default(FULL) @map("backup_type")
  scope        BackupScope @default(ALL) @map("scope")
  scopeDetails String[]    @default([]) @map("scope_details") // Specific tables if SELECTIVE

  // Status
  status       BackupStatus @default(PENDING)
  progress     Int          @default(0) // 0-100%
  errorMessage String?      @map("error_message") @db.Text

  // File Info
  fileName String? @map("file_name")
  filePath String? @map("file_path")
  fileSize BigInt? @map("file_size") // bytes
  checksum String? // MD5/SHA256 for integrity

  // Compression & Encryption
  isCompressed  Boolean @default(true) @map("is_compressed")
  isEncrypted   Boolean @default(true) @map("is_encrypted")
  encryptionKey String? @map("encryption_key") // Encrypted key reference

  // Stats
  totalRecords   Int?     @map("total_records")
  tablesIncluded String[] @default([]) @map("tables_included")

  // Scheduling
  isScheduled Boolean @default(false) @map("is_scheduled")
  scheduleId  Int?    @map("schedule_id")

  // Timestamps
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime? @map("expires_at") // Auto-delete after this date

  // User
  createdById Int      @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy   User            @relation("BackupCreatedBy", fields: [createdById], references: [id])
  schedule    BackupSchedule? @relation(fields: [scheduleId], references: [id])
  restoreJobs RestoreJob[]

  @@index([status])
  @@index([backupType])
  @@index([createdAt])
  @@index([createdById])
  @@map("backup_jobs")
}

model RestoreJob {
  id       Int    @id @default(autoincrement())
  jobCode  String @unique @map("job_code") // RST-YYYYMMDD-HHMMSS
  backupId Int    @map("backup_id")

  // Restore Options
  restoreType   RestoreType   @default(FULL) @map("restore_type")
  targetTables  String[]      @default([]) @map("target_tables") // If SELECTIVE
  overwriteMode OverwriteMode @default(SKIP_EXISTING) @map("overwrite_mode")

  // Status
  status       BackupStatus @default(PENDING)
  progress     Int          @default(0) // 0-100%
  errorMessage String?      @map("error_message") @db.Text

  // Stats
  recordsRestored Int? @map("records_restored")
  recordsSkipped  Int? @map("records_skipped")
  recordsFailed   Int? @map("records_failed")

  // Timestamps
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // User
  createdById Int      @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  backup    BackupJob @relation(fields: [backupId], references: [id])
  createdBy User      @relation("RestoreCreatedBy", fields: [createdById], references: [id])

  @@index([backupId])
  @@index([status])
  @@index([createdAt])
  @@map("restore_jobs")
}

model BackupSchedule {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  // Schedule Configuration
  frequency      ScheduleFrequency @default(DAILY)
  cronExpression String?           @map("cron_expression") // For advanced scheduling
  timeOfDay      String?           @map("time_of_day") // HH:mm format
  dayOfWeek      Int?              @map("day_of_week") // 0-6 for weekly
  dayOfMonth     Int?              @map("day_of_month") // 1-31 for monthly

  // Backup Settings
  backupType   BackupType  @default(FULL) @map("backup_type")
  scope        BackupScope @default(ALL) @map("scope")
  scopeDetails String[]    @default([]) @map("scope_details")
  isCompressed Boolean     @default(true) @map("is_compressed")
  isEncrypted  Boolean     @default(true) @map("is_encrypted")

  // Retention Policy
  retentionDays Int  @default(30) @map("retention_days") // Auto-delete after N days
  maxBackups    Int? @map("max_backups") // Keep only N latest backups

  // Storage Location
  storageType  StorageType @default(LOCAL) @map("storage_type")
  externalPath String?     @map("external_path") // Path for external storage (e.g., D:\Backups, \\server\backups)

  // Password Protection
  schedulePassword String? @map("schedule_password")

  // Status
  isActive   Boolean       @default(true) @map("is_active")
  lastRunAt  DateTime?     @map("last_run_at")
  nextRunAt  DateTime?     @map("next_run_at")
  lastStatus BackupStatus? @map("last_status")

  // User
  createdById Int      @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy  User        @relation("ScheduleCreatedBy", fields: [createdById], references: [id])
  backupJobs BackupJob[]

  @@index([isActive])
  @@index([nextRunAt])
  @@map("backup_schedules")
}

enum BackupType {
  FULL // สำรองทั้งหมด
  INCREMENTAL // สำรองเฉพาะที่เปลี่ยนแปลง
  DIFFERENTIAL // สำรองส่วนต่างจาก Full ล่าสุด
}

enum BackupScope {
  ALL // ทุกตาราง
  CORE // เฉพาะข้อมูลหลัก (Users, Incidents, Stores)
  TRANSACTIONS // เฉพาะ Transactions (Incidents, Comments, History)
  CONFIG // เฉพาะ Config (SLA, Categories, Roles)
  SELECTIVE // เลือกตาราง
}

enum StorageType {
  LOCAL // เก็บใน Local (./backups)
  EXTERNAL // เก็บที่ External path (Network drive, USB, etc.)
}

enum BackupStatus {
  PENDING // รอดำเนินการ
  RUNNING // กำลังทำงาน
  COMPLETED // สำเร็จ
  FAILED // ล้มเหลว
  CANCELLED // ยกเลิก
}

enum RestoreType {
  FULL // กู้คืนทั้งหมด
  SELECTIVE // กู้คืนเฉพาะบางตาราง
}

enum OverwriteMode {
  SKIP_EXISTING // ข้ามถ้ามีอยู่แล้ว
  OVERWRITE // เขียนทับ
  MERGE // รวมข้อมูล
}

enum ScheduleFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM // ใช้ cron expression
}

// ========================================
// LICENSE & ACTIVATION SYSTEM (Feature 17)
// ระบบใบอนุญาตและการเปิดใช้งาน
// ========================================

model License {
  id         Int    @id @default(autoincrement())
  licenseKey String @unique @map("license_key") // XXX-XXX-XXX-XXX format

  // License Info
  licenseType      LicenseType @default(TRIAL) @map("license_type")
  organizationName String      @map("organization_name")
  contactEmail     String      @map("contact_email")
  contactPhone     String?     @map("contact_phone")

  // Features & Limits
  maxUsers          Int      @default(10) @map("max_users")
  maxStores         Int      @default(5) @map("max_stores")
  maxIncidentsMonth Int?     @map("max_incidents_month") // null = unlimited
  featuresEnabled   String[] @default([]) @map("features_enabled") // Feature flags

  // Validity
  issuedAt    DateTime  @default(now()) @map("issued_at")
  activatedAt DateTime? @map("activated_at")
  expiresAt   DateTime  @map("expires_at")

  // Status
  status LicenseStatus @default(INACTIVE)

  // Hardware Binding
  machineId    String?  @map("machine_id") // Primary bound machine (first activation)
  machineIds   String[] @default([]) @map("machine_ids") // All bound machines (Volume License)
  hardwareHash String?  @map("hardware_hash")

  // Activation History
  activationCount  Int       @default(0) @map("activation_count")
  maxActivations   Int       @default(1) @map("max_activations") // >1 = Volume License
  lastActivationAt DateTime? @map("last_activation_at")
  lastCheckAt      DateTime? @map("last_check_at")

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activationLogs LicenseActivationLog[]

  @@index([status])
  @@index([expiresAt])
  @@index([licenseType])
  @@map("licenses")
}

model LicenseActivationLog {
  id        Int @id @default(autoincrement())
  licenseId Int @map("license_id")

  // Action
  action LicenseAction

  // Details
  machineId String? @map("machine_id")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text

  // Result
  success      Boolean
  errorMessage String? @map("error_message")

  // Metadata
  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([action])
  @@index([createdAt])
  @@map("license_activation_logs")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  category    String   @default("general")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_configs")
}

enum LicenseType {
  TRIAL // ทดลองใช้ 14-30 วัน
  BASIC // Basic plan
  PROFESSIONAL // Professional plan
  ENTERPRISE // Enterprise plan
  UNLIMITED // Unlimited (internal use)
}

enum LicenseStatus {
  INACTIVE // ยังไม่ได้เปิดใช้งาน
  ACTIVE // กำลังใช้งาน
  EXPIRED // หมดอายุ
  SUSPENDED // ถูกระงับ
  REVOKED // ถูกเพิกถอน
}

enum LicenseAction {
  ACTIVATE // เปิดใช้งาน
  DEACTIVATE // ปิดใช้งาน
  REACTIVATE // เปิดใช้งานใหม่
  VALIDATE // ตรวจสอบ
  RENEW // ต่ออายุ
  UPGRADE // อัปเกรด
  TRANSFER // โอนย้าย
}

// ==========================================
// Audit Trail (Cross-Module)
// ==========================================

enum AuditModule {
  INCIDENT
  STORE
  EQUIPMENT
  USER
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ASSIGN
  REASSIGN
  RESOLVE
  CONFIRM
  REOPEN
  CANCEL
  TRANSFER
  IMPORT
  EXPORT
  LOGIN
  LOGOUT
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  module      AuditModule
  action      AuditAction
  entityType  String      @map("entity_type")
  entityId    String      @map("entity_id")
  userId      Int         @map("user_id")
  description String      @db.Text
  oldValue    String?     @map("old_value") @db.Text
  newValue    String?     @map("new_value") @db.Text
  ipAddress   String?     @map("ip_address")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Multi-technician Assignment (Many-to-Many)
model IncidentAssignee {
  id               Int       @id @default(autoincrement())
  incidentId       String    @map("incident_id")
  userId           Int       @map("user_id")
  assignedAt       DateTime  @default(now()) @map("assigned_at")
  checkedInAt      DateTime? @map("checked_in_at")
  checkInLatitude  Float?    @map("check_in_latitude")
  checkInLongitude Float?    @map("check_in_longitude")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation("IncidentAssignees", fields: [userId], references: [id])

  @@unique([incidentId, userId])
  @@index([incidentId])
  @@index([userId])
  @@map("incident_assignees")
}

// SLA Defense Request
model SlaDefense {
  id           Int              @id @default(autoincrement())
  incidentId   String           @map("incident_id")
  technicianId Int              @map("technician_id")
  reason       String           @db.Text
  status       SlaDefenseStatus @default(PENDING)
  reviewedById Int?             @map("reviewed_by_id")
  reviewedAt   DateTime?        @map("reviewed_at")
  reviewNote   String?          @map("review_note") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  technician User     @relation("SlaDefenseTechnician", fields: [technicianId], references: [id])
  reviewedBy User?    @relation("SlaDefenseReviewer", fields: [reviewedById], references: [id])

  @@index([incidentId])
  @@index([status])
  @@map("sla_defenses")
}

// ============================================================
// Preventive Maintenance (PM)
// ============================================================

model PmRecord {
  id           Int    @id @default(autoincrement())
  incidentId   String @unique @map("incident_id")
  storeId      Int    @map("store_id")
  technicianId Int?   @map("technician_id")

  performedAt DateTime? @map("performed_at")

  // Inventory List online signature
  inventoryListToken          String?   @unique @map("inventory_list_token")
  inventoryListTokenExpiresAt DateTime? @map("inventory_list_token_expires_at")
  storeSignature              String?   @map("store_signature") @db.Text
  storeSignerName             String?   @map("store_signer_name")
  storeSignedAt               DateTime? @map("store_signed_at")
  signedInventoryPhoto        String?   @map("signed_inventory_photo") @db.Text

  incident         Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  store            Store               @relation(fields: [storeId], references: [id])
  equipmentRecords PmEquipmentRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([inventoryListToken])
  @@map("pm_records")
}

model PmEquipmentRecord {
  id          Int @id @default(autoincrement())
  pmRecordId  Int @map("pm_record_id")
  equipmentId Int @map("equipment_id")

  beforePhotos String[] @default([]) @map("before_photos")
  afterPhotos  String[] @default([]) @map("after_photos")
  comment      String?  @db.Text
  condition    String? // GOOD | NEEDS_REPAIR | REPLACED

  // Fields to update on Equipment table when PM is submitted
  updatedBrand  String? @map("updated_brand")
  updatedModel  String? @map("updated_model")
  updatedSerial String? @map("updated_serial")

  pmRecord  PmRecord  @relation(fields: [pmRecordId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pmRecordId])
  @@index([equipmentId])
  @@map("pm_equipment_records")
}

// ─── Version Management ───────────────────────────────────────────────────────

enum VersionStatus {
  CURRENT
  PREVIOUS
  FAILED
}

model AppVersion {
  id           Int           @id @default(autoincrement())
  version      String        @unique // e.g. "1.1.0"
  fromVersion  String?       @map("from_version") // e.g. "1.0.0"
  status       VersionStatus @default(CURRENT)
  releaseNotes String?       @map("release_notes") @db.Text
  changes      Json          @default("[]") // [{type, desc}]
  appliedAt    DateTime      @default(now()) @map("applied_at")
  appliedById  Int?          @map("applied_by_id")
  appliedBy    User?         @relation(fields: [appliedById], references: [id], onDelete: SetNull)
  snapshotPath String?       @map("snapshot_path")
  checksum     String?

  @@map("app_versions")
}

model Patch {
  id            Int       @id @default(autoincrement())
  version       String // e.g. "1.2.3"
  patchType     String    @map("patch_type") // "HOTFIX" | "FEATURE" | "SECURITY" | "MAINTENANCE"
  title         String
  changelog     String    @db.Text
  fileName      String    @map("file_name") // original filename
  filePath      String    @map("file_path") // stored path under uploads/patches/
  fileSize      Int       @map("file_size") // bytes
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  emailSentAt   DateTime? @map("email_sent_at")
  downloadCount Int       @default(0) @map("download_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("patches")
}
