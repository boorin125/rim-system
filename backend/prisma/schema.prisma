  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model StoreDeleteRequest {
