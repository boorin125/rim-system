// ========================================
// INCIDENT RATING SYSTEM (Feature 8)
// Public Link Rating - ลูกค้าประเมินช่างหลังปิดงาน
// ========================================

model IncidentRating {
  id         Int    @id @default(autoincrement())
  incidentId String @unique @map("incident_id")

  // Overall Rating (1-5)
  rating  Int     @db.SmallInt
  comment String? @db.Text

  // Detailed Ratings (Optional, 1-5)
  qualityRating         Int? @map("quality_rating") @db.SmallInt
  professionalismRating Int? @map("professionalism_rating") @db.SmallInt
  politenessRating      Int? @map("politeness_rating") @db.SmallInt

