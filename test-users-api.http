POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "bulk.user.001",
  "email": "bulk001@rim.com",
  "password": "password123",
  "firstName": "Bulk",
  "lastName": "User 001",
  "role": "END_USER",
  "status": "ACTIVE"
}

### ============================================
### SUMMARY OF ALL USER ENDPOINTS
### ============================================
# POST   /api/auth/login                    - Login
# POST   /api/users                         - Create User
# GET    /api/users                         - Get All Users
# GET    /api/users?page=1&limit=10         - Get Users with Pagination
# GET    /api/users?role=TECHNICIAN         - Get Users by Role
# GET    /api/users?status=ACTIVE           - Get Users by Status
# GET    /api/users?search=john             - Search Users
# GET    /api/users/:id                     - Get User by ID
# PATCH  /api/users/:id                     - Update User
# POST   /api/users/:id/change-password     - Change Password
# POST   /api/users/:id/update-status       - Update Status
# POST   /api/users/:id/unlock              - Unlock Account
# GET    /api/users/:id/incidents           - Get User Incidents
# GET    /api/users/:id/statistics          - Get User Statistics
# DELETE /api/users/:id                     - Delete User

### ============================================
### EXPECTED RESPONSES
### ============================================
# 200 OK          - Successful GET/PATCH/POST
# 201 Created     - Successful POST (Create)
# 204 No Content  - Successful DELETE
# 400 Bad Request - Validation Error
# 401 Unauthorized - Missing/Invalid Token
# 403 Forbidden   - Insufficient Permissions
# 404 Not Found   - Resource Not Found
# 500 Internal Server Error - Server Error

### ============================================
### NOTES
### ============================================
# 1. Update @token variable after login
# 2. Replace user IDs (e.g., /users/5) with actual IDs from your database
# 3. Some operations require specific roles (SUPER_ADMIN, IT_MANAGER)
# 4. Password must be at least 8 characters
# 5. Valid roles: SUPER_ADMIN, IT_MANAGER, SUPERVISOR, HELP_DESK, TECHNICIAN, END_USER
# 6. Valid statuses: ACTIVE, INACTIVE, SUSPENDED
# 7. Soft delete means user is marked as deleted but not physically removed

### ============================================
### END OF USER API TESTS
### ============================================
