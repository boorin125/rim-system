### ============================================
### STEP 1: Login to Get Token
### ============================================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "superadmin@rim.com",
  "password": "password123"
}

### After login, copy accessToken and update @token variable above

### ============================================
### USER MANAGEMENT APIs
### ============================================

### ============================================
### STEP 2: Get All Users
### ============================================
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### ============================================
### STEP 3: Get All Users (with Pagination)
### ============================================
GET {{baseUrl}}/users?page=1&limit=5
Authorization: Bearer {{token}}

### ============================================
### STEP 4: Get All Users (with Filters)
### ============================================

### Filter by Role
GET {{baseUrl}}/users?role=TECHNICIAN
Authorization: Bearer {{token}}

###

### Filter by Status
GET {{baseUrl}}/users?status=ACTIVE
Authorization: Bearer {{token}}

###

### Filter by Multiple Criteria
GET {{baseUrl}}/users?role=HELP_DESK&status=ACTIVE
Authorization: Bearer {{token}}

### ============================================
### STEP 5: Get All Users (with Search)
### ============================================
GET {{baseUrl}}/users?search=admin
Authorization: Bearer {{token}}

### ============================================
### STEP 6: Get User by ID
### ============================================
GET {{baseUrl}}/users/7
Authorization: Bearer {{token}}

### ============================================
### STEP 7: Create New User
### ============================================

### Create Technician
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "tech.john",
  "email": "john.tech@rim.com",
  "password": "password123",
  "firstName": "John",
  "lastName": "Technician",
  "phone": "081-111-2222",
  "role": "TECHNICIAN",
  "status": "ACTIVE"
}

###

### Create Help Desk
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "helpdesk.sarah",
  "email": "sarah.helpdesk@rim.com",
  "password": "password123",
  "firstName": "Sarah",
  "lastName": "Support",
  "phone": "081-333-4444",
  "role": "HELP_DESK",
  "status": "ACTIVE"
}

###

### Create IT Manager
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "manager.bob",
  "email": "bob.manager@rim.com",
  "password": "password123",
  "firstName": "Bob",
  "lastName": "Manager",
  "phone": "081-555-6666",
  "role": "IT_MANAGER",
  "status": "ACTIVE"
}

###

### Create End User
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "user.alice",
  "email": "alice.user@rim.com",
  "password": "password123",
  "firstName": "Alice",
  "lastName": "Store Manager",
  "phone": "081-777-8888",
  "role": "END_USER",
  "status": "ACTIVE"
}

### ============================================
### STEP 8: Update User
### ============================================

### Update User Profile
PATCH {{baseUrl}}/users/7
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "John Updated",
  "lastName": "Tech",
  "phone": "082-999-9999"
}

###

### Update User Email
PATCH {{baseUrl}}/users/7
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "john.updated@rim.com"
}

###

### Update User Role
PATCH {{baseUrl}}/users/7
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "role": "SUPERVISOR"
}

### ============================================
### STEP 9: Change User Password
### ============================================
POST {{baseUrl}}/users/7/change-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "newPassword": "newpassword123"
}

### ============================================
### STEP 10: Update User Status
### ============================================

### Set to INACTIVE
POST {{baseUrl}}/users/7/update-status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "INACTIVE"
}

###

### Set to ACTIVE
POST {{baseUrl}}/users/7/update-status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "ACTIVE"
}

###

### Set to SUSPENDED
POST {{baseUrl}}/users/7/update-status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "SUSPENDED"
}

### ============================================
### STEP 11: Unlock User Account
### ============================================
# Use this when user is locked due to failed login attempts
POST {{baseUrl}}/users/7/unlock
Authorization: Bearer {{token}}

### ============================================
### STEP 12: Get User Incidents
### ============================================
# Get all incidents assigned to or created by this user
GET {{baseUrl}}/users/7/incidents
Authorization: Bearer {{token}}

###

# Get User Incidents with Pagination
GET {{baseUrl}}/users/7/incidents?page=1&limit=10
Authorization: Bearer {{token}}

###

# Get User Incidents with Filters
GET {{baseUrl}}/users/7/incidents?status=OPEN
Authorization: Bearer {{token}}

### ============================================
### STEP 13: Get User Statistics
### ============================================
# Get statistics for a specific user
GET {{baseUrl}}/users/7/statistics
Authorization: Bearer {{token}}

### ============================================
### STEP 14: Delete User (Soft Delete)
### ============================================
DELETE {{baseUrl}}/users/7
Authorization: Bearer {{token}}

